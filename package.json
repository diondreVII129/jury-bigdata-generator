{
  "name": "jury-bigdata-generator",
  "version": "1.0.0",
  "description": "Generates 55,200 synthetic jurors for 46 South Carolina counties using the Anthropic API",
  "main": "dist/index.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "setup": "tsx scripts/setup-database.ts",
    "generate": "tsx scripts/generate-county.ts",
    "generate-all": "tsx scripts/generate-all-counties.ts",
    "verify": "tsx scripts/verify-generation.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "pg": "^8.13.1",
    "tsx": "^4.19.2",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.0.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
